# ══════════════════════════════════════════════════════════════
#  RoomBandhu — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ══════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-minimum-32-chars
FLASK_ENV=development          # change to "production" on live server

# ── Database ───────────────────────────────────────────────────
# Leave blank to use SQLite locally (roombandhu.db will be created automatically)
# On Render: this is set automatically from the database service
DATABASE_URL=

# ── Email (Gmail example) ──────────────────────────────────────
# Use an App Password, NOT your real Gmail password.
# Enable 2FA on your Google account → Security → App Passwords → generate one.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=RoomBandhu <your@gmail.com>

# ── Google OAuth ───────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/
# Authorised redirect URI: http://localhost:5000/auth/google/callback (dev)
#                          https://yourdomain.com/auth/google/callback (prod)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Admin Panel ────────────────────────────────────────────────
ADMIN_EMAIL=admin@roombandhu.com
ADMIN_PASSWORD=Admin@Secure123   # Change this before deploying!
